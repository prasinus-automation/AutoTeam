# ─── Required ─────────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=yourusername/yourproject

# ─── Claude Auth (pick ONE) ──────────────────────────
# Option A: API key (pay-per-token)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Option B: Claude subscription (Pro/Max — $20-100/mo)
# 1. Run `claude` on your host machine and complete the browser login
# 2. Set the path to your credentials file:
# CLAUDE_CREDENTIALS_PATH=/home/yourusername/.claude/.credentials.json
# 3. Comment out or clear ANTHROPIC_API_KEY above

# ─── Daemon Mode ──────────────────────────────────────
MODE=webhook               # "webhook" (instant) or "poll" (fallback)
WEBHOOK_PORT=9876          # port the webhook server listens on
WEBHOOK_SECRET=your_secret # must match GitHub webhook config — generate with: openssl rand -hex 20
# Optional: the GitHub login the daemon's GITHUB_TOKEN authenticates as.
# Used as the author-allowlist gate for QA/Security verdict comments (#66).
# If unset, the daemon resolves it via `GET /user` at startup. Webhook mode
# refuses to start if neither path succeeds.
# BOT_LOGIN=my-bot-account

# ─── Optional ─────────────────────────────────────────
POLL_INTERVAL=30           # seconds between polls (only used in poll mode)
MAX_FRONTEND_AGENTS=2      # max concurrent frontend-dev agents
MAX_BACKEND_AGENTS=2       # max concurrent backend-dev agents
MAX_FULLSTACK_AGENTS=1     # max concurrent fullstack-dev agents
MAX_FIX_ITERATIONS=3       # max review/fix cycles per PR before requesting human help
MAX_TOTAL_AGENTS=3         # max concurrent agent containers (hard cap, prevents runaway)
DAILY_BUDGET_USD=0         # 0 = no cap; otherwise refuse new spawns once today's spend exceeds this
BLOCKED_SWEEP_INTERVAL_MIN=30  # how often (minutes) to sweep `blocked` issues for self-healed unblocks; 0 disables (a startup sweep still runs)
